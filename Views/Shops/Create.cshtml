@{
    ViewData["Title"] = "Index";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<section class="pt-4 mb-4">
    <div class="container text-center">
        <div class="row">
            <div class="col-lg-6 text-center text-lg-left">
                <h1 class="fw-600 h4">Đăng ký gian hàng</h1>
            </div>
            <div class="col-lg-6">
                <ul class="breadcrumb bg-transparent p-0 justify-content-center justify-content-lg-end">
                    <li class="breadcrumb-item opacity-50">
                        <a class="text-reset" href="/">Trang Chủ</a>
                    </li>
                    <li class="text-dark fw-600 breadcrumb-item">
                        <a class="text-reset" href="/shops/create">"Đăng ký gian hàng"</a>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</section>
<section class="pt-4 mb-4">
    <div class="container">
        <div class="row">
            <div class="col-xxl-5 col-xl-6 col-md-8 mx-auto">
                <form id="shop" class="" action="/shops" method="POST" enctype="multipart/form-data" data-gtm-form-interact-id="0">
                    <input type="hidden" name="_token" value="bxvaeuYGQGnn71WcTOC0BywuXOaiUg3Vz3f1ioTc">                                        <div class="bg-white rounded shadow-sm mb-4">
                        <div class="fs-15 fw-600 p-3 border-bottom">
                            Thông tin
                        </div>
                        <div class="p-3">
                            <div class="form-group">
                                <label>Tên người đại diện <span class="text-primary">*</span></label>
                                <input type="text" class="form-control" placeholder="Tên người đại diện" name="manager" required="" data-gtm-form-interact-field-id="0">
                            </div>
                            <div class="form-group">
                                <label>Tên gian hàng <span class="text-primary">*</span></label>
                                <input type="text" class="form-control" placeholder="Tên gian hàng" name="name" required="">
                            </div>
                            <div class="form-group">
                                <label>Điện thoại của cửa hàng <span class="text-primary">*</span></label>
                                <input type="text" class="form-control mb-3" placeholder="Điện thoại của cửa hàng" name="shop_phone" required="">
                            </div>
                        </div>
                    </div>


                    <div class="text-right">
                        <button type="submit" class="btn btn-primary fw-600">Đăng ký gian hàng</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>