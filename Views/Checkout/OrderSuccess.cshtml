@model UC.eComm.Publish.Controllers.OrderSuccessViewModel
@{
    ViewData["Title"] = "Đặt hàng thành công";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-success text-white">
                    <h3 class="mb-0">Đặt hàng thành công!</h3>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <h5>Thông tin đơn hàng</h5>
                            <table class="table table-borderless">
                                <tr><th>Mã đơn:</th><td>@Model.OrderId</td></tr>
                                <tr><th>Khách hàng:</th><td>@Model.CustomerName</td></tr>
                                <tr><th>Điện thoại:</th><td>@Model.Phone</td></tr>
                                <tr><th>Địa chỉ giao:</th><td>@Model.Address</td></tr>
                                <tr><th>Tổng tiền:</th><td>@Model.TotalAmount.ToString("N0") VND</td></tr>
                                @if (Model.Latitude.HasValue)
                                {
                                    <tr><th>Tọa độ:</th><td>@Model.Latitude.Value.ToString("F6"), @Model.Longitude.Value.ToString("F6")</td></tr>
                                }
                            </table>
                            <p class="text-muted">Thanh toán khi nhận hàng (COD)</p>
                        </div>
                        <div class="col-md-6 text-center">
                            <h5>Mã QR giao hàng</h5>
                            <p class="small">Dành cho nhân viên giao hàng quét</p>
                            <img src="data:image/png;base64,@Model.QrCodeBase64" class="img-fluid border p-2" style="max-height:300px;" />
                            <p class="mt-2">
                                <button class="btn btn-outline-primary btn-sm" type="button" data-toggle="collapse" data-target="#qrDataCollapse">
                                    Xem dữ liệu QR
                                </button>
                            </p>
                            <div class="collapse" id="qrDataCollapse">
                                <pre class="bg-light p-2 small text-left">@Model.FullQrData</pre>
                            </div>
                        </div>
                    </div>
                    <hr />
                    <div class="text-center">
                        <a href="/" class="btn btn-primary">Tiếp tục mua sắm</a>
                        <a href="#" class="btn btn-outline-secondary">Theo dõi đơn hàng</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>