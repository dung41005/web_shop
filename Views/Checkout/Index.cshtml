@{
    ViewData["Title"] = "Index";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<section class="pt-5 mb-4">
    <div class="container">
        <div class="row">
            <div class="col-xl-8 mx-auto">
                <div class="row aiz-steps arrow-divider">
                    <div class="col done">
                        <div class="text-center text-success">
                            <i class="la-3x mb-2 las la-shopping-cart"></i>
                            <h3 class="fs-14 fw-600 d-none d-lg-block ">1. Giỏ hàng</h3>
                        </div>
                    </div>
                    <div class="col active">
                        <div class="text-center text-primary">
                            <i class="la-3x mb-2 las la-map"></i>
                            <h3 class="fs-14 fw-600 d-none d-lg-block ">2. Thông tin nhận hàng</h3>
                        </div>
                    </div>
                    <div class="col">
                        <div class="text-center">
                            <i class="la-3x mb-2 opacity-50 las la-credit-card"></i>
                            <h3 class="fs-14 fw-600 d-none d-lg-block opacity-50 ">3. Thanh toán</h3>
                        </div>
                    </div>
                    <div class="col">
                        <div class="text-center">
                            <i class="la-3x mb-2 opacity-50 las la-check-circle"></i>
                            <h3 class="fs-14 fw-600 d-none d-lg-block opacity-50 ">Hoàn tất</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<section class="mb-4 gry-bg">
    <div class="container">
        <div class="row cols-xs-space cols-sm-space cols-md-space">
            <div class="col-xxl-8 col-xl-10 mx-auto">
                <form class="form-default" data-toggle="validator" action="/checkout/payment_select" role="form" method="POST">
                    <input type="hidden" name="_token" value="bxvaeuYGQGnn71WcTOC0BywuXOaiUg3Vz3f1ioTc">
                    <div class="shadow-sm bg-white p-4 rounded mb-4">
                        <div id="info-addresses" class="row gutters-5">
                            @for (int i = 0; i < Model.addressCookies.Count; i++)
                            {
                                <div class="col-md-6 mb-3">
                                    <label class="aiz-megabox d-block bg-white mb-0">
                                        @if(i == 0){
                                            <input type="radio" name="address_id" value="@Model.addressCookies[i].Id" checked required>
                                        }else{
                                            <input type="radio" name="address_id" value="@Model.addressCookies[i].Id" required>
                                        }
                                        <span class="d-flex p-3 aiz-megabox-elem">
                                            <span class="aiz-rounded-check flex-shrink-0 mt-1"></span>
                                            <span class="flex-grow-1 pl-3 text-left">
                                                <div>
                                                    <span class="opacity-60">Người nhận:</span>
                                                    <span class="fw-600 ml-2">@Model.addressCookies[i].RecipientName</span>
                                                </div>
                                                <div>
                                                    <span class="opacity-60">Địa chỉ:</span>
                                                    <span class="fw-600 ml-2">@Model.addressCookies[i].Address</span>
                                                </div>
                                                <div>
                                                    <span class="opacity-60">Phường / Xã:</span>
                                                    <span class="fw-600 ml-2">@Model.addressCookies[i].Ward</span>
                                                </div>
                                                <div>
                                                    <span class="opacity-60">Quận / Huyện:</span>
                                                    <span class="fw-600 ml-2">@Model.addressCookies[i].District</span>
                                                </div>
                                                <div>
                                                    <span class="opacity-60">Tỉnh / Thành phố:</span>
                                                    <span class="fw-600 ml-2">@Model.addressCookies[i].Province</span>
                                                </div>
                                                <div>
                                                    <span class="opacity-60">Điện thoại:</span>
                                                    <span class="fw-600 ml-2">@Model.addressCookies[i].Phone</span>
                                                </div>
                                            </span>
                                        </span>
                                    </label>
                                    <div class="dropdown position-absolute right-0 top-0">
                                        <button class="btn bg-gray px-2" type="button" data-toggle="dropdown">
                                            <i class="la la-ellipsis-v"></i>
                                        </button>
                                        <div class="dropdown-menu dropdown-menu-right" aria-labelledby="dropdownMenuButton">
                                            <a class="dropdown-item" onclick="showModalAdress(@Model.addressCookies[i].Id)">
                                                Cập nhật
                                            </a>
                                            <a class="dropdown-item" onclick="removeAddress(@Model.addressCookies[i].Id)">
                                                Xóa
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            }
                            <input type="hidden" name="checkout_type" value="logged">
                            <div class="col-md-6 mx-auto mb-3">
                                <div class="border p-3 rounded mb-3 c-pointer text-center bg-white h-100 d-flex flex-column justify-content-center" onclick="add_new_address()">
                                    <i class="las la-plus la-2x mb-3"></i>
                                    <div class="alpha-7">Thêm địa chỉ mới</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    @foreach (var product in Model.cartItems)
                    {
                        <div class="card mb-3 shadow-sm border-0 rounded">
                            <div class="card-header p-3">
                                    <h5 class="fs-16 fw-600 mb-0">@product.Company</h5>
                            </div>
                            <div class="card-body">
                                <ul class="list-group list-group-flush">
                                    <li class="list-group-item">
                                        <div class="d-flex">
                                            <span class="mr-2">
                                                <img src="@product.Image.Split('|')[0]" class="img-fit size-60px rounded" alt="@product.Name">
                                            </span>
                                            <span class="fs-14 opacity-60">@product.Name</span>
                                        </div>
                                    </li>
                                </ul>

                            </div>
                        </div>
                    }
                    <div class="pt-4 d-flex justify-content-between align-items-center">
                        <a href="/">
                            <i class="la la-angle-left"></i>
                            Quay lại cửa hàng
                        </a>
                        <button type="submit"  class="btn fw-600 btn-primary">Thanh toán và đặt hàng</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>
<div class="modal fade" id="chat_modal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-zoom product-modal" id="modal-size" role="document">
        <div class="modal-content position-relative">
            <div class="modal-header">
                <h5 class="modal-title fw-600 h5">Thắc mắc về sản phẩm này</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form class="" action="#" method="POST" enctype="multipart/form-data">
                <input type="hidden" name="_token" value="Rapszq8xJNxverrIcn23lyALd25Ta0ufT7Voo3le">
                <input type="hidden" name="product_id" value="15742">
                <div class="modal-body gry-bg px-3 pt-3">
                    <div class="form-group">
                        <input type="text" class="form-control mb-3" name="title" value="Thịt trâu gác bếp đậm đà tươi ngon 1kg" placeholder="Tên sản phẩm" required>
                    </div>
                    <div class="form-group">
                        <textarea class="form-control" rows="8" name="message" required placeholder="Câu hỏi"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-primary fw-600" data-dismiss="modal">Huỷ bỏ</button>
                    <button type="submit" class="btn btn-primary fw-600">Gửi</button>
                </div>
            </form>
        </div>
    </div>
</div>
<div class="modal fade" id="new-address-modal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLabel">Địa chỉ mới</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form class="form-default" role="form" id="option-choice-form">
                <input type="hidden" name="_token" value="bxvaeuYGQGnn71WcTOC0BywuXOaiUg3Vz3f1ioTc">
                <div class="modal-body">
                    <div class="p-3">
                        <div class="row">
                            <div class="col-md-3">
                                <label>Họ tên người nhận</label>
                            </div>
                            <div class="col-md-9">
                                <input type="text" class="form-control mb-3" placeholder="Nguyễn Văn A" name="recipient_name" required>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-3">
                                <label>Địa chỉ</label>
                            </div>
                            <div class="col-md-9">
                                <textarea class="form-control mb-3" placeholder="Địa chỉ của bạn" rows="2" name="address" required ></textarea>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-3">
                                <label>Tỉnh / Thành phố</label>
                            </div>
                            <div class="col-md-9">
                                <select class="form-control mb-3 aiz-selectpicker" data-live-search="true" name="province_id" required tabindex="-98">
                                    <option value="">Chọn Tỉnh / Thành phố</option>
                                    @foreach (var item in Model.addresses)
                                    {
                                        <option value="@item.ProvinceId">@item.Province</option>
                                    }
                                </select>
                                
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-3">
                                <label>Quận / Huyện</label>
                            </div>
                            <div class="col-md-9">
                                    <select class="form-control mb-3 aiz-selectpicker" data-live-search="true" name="district_id" required tabindex="-98">
                                    </select>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-3">
                                <label>Phường / Xã</label>
                            </div>
                            <div class="col-md-9">
                                    <select class="form-control mb-3 aiz-selectpicker" data-live-search="true" name="ward_id" required tabindex="-98">
                                    </select>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-3">
                                <label>Điện thoại</label>
                            </div>
                            <div class="col-md-9">
                                <input type="text" class="form-control mb-3" placeholder="+84" name="phone" value="" required>
                            </div>
                        </div>
                        <div class="form-group text-right">
                            <button type="button" onclick="submitAddress()" class="btn btn-sm btn-primary">Lưu</button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
<div class="modal fade" id="edit-address-modal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" style="z-index: 1040; display: none;" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLabel">Địa chỉ mới</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>

            <div class="modal-body" id="edit_modal_body">
                
            </div>
        </div>
    </div>
</div>