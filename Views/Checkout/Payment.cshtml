@model UC.eComm.Publish.Controllers.OrderModel
@using UC.eComm.Publish.Utilities

@{
    string qrBase64 = GenQRNapas.GenerateQRUCVN(
        (int)Model.TotalPrice,
        Model.OrderId,
        Model.CustomerName
    );
}
@{
    ViewData["Title"] = "Index";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<section class="pt-5 mb-4">
    <div class="container">
        <div class="row">
            <div class="col-xl-8 mx-auto">
                <div class="row aiz-steps arrow-divider">
                    <div class="col done">
                        <div class="text-center text-success">
                            <i class="la-3x mb-2 las la-shopping-cart"></i>
                            <h3 class="fs-14 fw-600 d-none d-lg-block">1. Giỏ hàng</h3>
                        </div>
                    </div>
                    <div class="col done">
                        <div class="text-center text-success">
                            <i class="la-3x mb-2 las la-map"></i>
                            <h3 class="fs-14 fw-600 d-none d-lg-block">2. Thông tin nhận hàng</h3>
                        </div>
                    </div>
                    <div class="col done">
                        <div class="text-center text-success">
                            <i class="la-3x mb-2 las la-credit-card"></i>
                            <h3 class="fs-14 fw-600 d-none d-lg-block">3. Thanh toán</h3>
                        </div>
                    </div>
                    <div class="col active">
                        <div class="text-center text-primary">
                            <i class="la-3x mb-2 opacity-50 las la-check-circle"></i>
                            <h3 class="fs-14 fw-600 d-none d-lg-block opacity-50">Hoàn tất</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<section class="mb-4">
    <div class="container text-left">
        <div class="row">
            <div class="col-lg-8">
                <form action="/payment" class="form-default" role="form" method="POST" id="checkout-form">
                    <input type="hidden" name="_token" value="bxvaeuYGQGnn71WcTOC0BywuXOaiUg3Vz3f1ioTc">                    <input type="hidden" name="owner_id" value="3240">

                    <div class="card shadow-sm border-0 rounded">
                        <div class="card-header p-3">
                            <h3 class="fs-16 fw-600 mb-0">
                                Thanh toán ngay
                            </h3>
                        </div>
                        <div class="card-body text-center">
                            <div class="row">
                                <div class="col-xxl-10 col-xl-12 mx-auto">
                                    <div class="row gutters-10">
                                        <div class="col-6 col-md-6">
                                            <img src="data:image/png;base64,@qrBase64" class="img-fluid">
                                        </div>
                                        <div class="col-6 col-md-6">
                                            <label class="aiz-megabox d-block mt-4 mb-3">

                                                <span class="d-block p-3 aiz-megabox-elem">

                                                    <span class="d-block text-center">
                                                        <span class="d-block fw-600 fs-15">Quý khách quyét mã QR này để thanh toán cho đơn hàng</span>
                                                        <div class="mt-3 text-center">
                                                            <p><strong>Mã đơn:</strong> @Model.OrderId</p>
                                                            <p><strong>Số tiền:</strong> @Model.TotalPrice.ToString("N0") VND</p>
                                                            <p><strong>Nội dung CK:</strong></p>
                                                            <p class="text-danger fw-600">
                                                                @Model.OrderId - @Model.CustomerName
                                                            </p>
                                                            <p><strong>Ngân hàng:</strong> MB Bank</p>
                                                            <p><strong>STK:</strong> 0398398205</p>
                                                            <p><strong>Chủ TK:</strong> Lương Anh Dũng</p>
                                                        </div>
                                                    </span>
                                                </span>
                                            </label>
                                        </div>
                                        <style type="text/css">
                                            .aiz-megabox img {
                                                height: 50px;
                                            }
                                        </style>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>


                    <div class="row align-items-center pt-3">
                        <div class="col-6">
                            <a href="/" class="link link--style-3">
                                <i class="las la-arrow-left"></i>
                                Quay lại cửa hàng
                            </a>
                        </div>

                    </div>
                </form>
            </div>

            <div class="col-lg-4 mt-4 mt-lg-0" id="cart_summary">
                <div class="card border-0 shadow-sm rounded">
                    <div class="card-header">
                        <h3 class="fs-16 fw-600 mb-0">Tóm tắt</h3>
                        <div class="text-right">
                            <span class="badge badge-inline badge-primary">
                                @Model.CartItems.Count
                                Mặt hàng
                            </span>
                        </div>
                    </div>

                    <div class="card-body">
                        <!-- Bảng danh sách sản phẩm -->
                        <table class="table table-borderless">
                            <thead>
                                <tr>
                                    <th class="product-name">Sản phẩm</th>
                                    <th class="product-total text-right">TỔNG TIỀN</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.CartItems)
                                {
                                    <tr class="cart_item">
                                        <td class="product-name">
                                            @item.Name
                                            <strong class="product-quantity">
                                                × @item.Quantity
                                            </strong>
                                        </td>
                                        <td class="product-total text-right">
                                            <span class="pl-4 pr-0">@item.TotalPrice.ToString("N0") VND</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                        <!-- Bảng tổng kết -->
                        <table class="table table-borderless">
                            <tfoot>
                                <tr class="cart-subtotal">
                                    <th>Tạm tính</th>
                                    <td class="text-right">
                                        <span class="fw-600">@Model.TotalPrice.ToString("N0") VND</span>
                                    </td>
                                </tr>
                                <tr class="cart-shipping">
                                    <th>Tổng phí giao hàng</th>
                                    <td class="text-right">
                                        <span class="font-italic">0 VND</span>
                                    </td>
                                </tr>
                                <tr class="cart-total">
                                    <th><span class="strong-600">TỔNG TIỀN</span></th>
                                    <td class="text-right">
                                        <strong><span>@Model.TotalPrice.ToString("N0") VND</span></strong>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
