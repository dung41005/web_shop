@{
    ViewData["Title"] = "Index";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="modal fade" id="order_details" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl" role="document">
        <div class="modal-content">
            <div id="order-details-modal-body">
            </div>
        </div>
    </div>
</div>
<section class="mb-4 pt-3">
    <div class="container">
        <div class="bg-white shadow-sm rounded p-3">
            <div class="row">
                <div class="col-xl-5 col-lg-6 mb-4">
                    <div class="sticky-top z-3 row gutters-10">
                        <div class="col order-1 order-md-2">
                            <div class="aiz-carousel product-gallery" data-nav-for=".product-gallery-thumb" data-fade="true" data-auto-height="true">
                                @foreach (var item in Model.Product.Image.Split('|'))
                                {
                                    @if (!String.IsNullOrEmpty(item))
                                    {
                                        <div>
                                            <div class="carousel-box img-zoom rounded" style="width: 100%; display: inline-block; position: relative; overflow: hidden;">
                                                <img class="img-fluid ls-is-cached lazyloaded" src="@item" data-src="@item" onerror="this.onerror=null;this.src='/img/placeholder.jpg';">
                                                
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                        <div class="col-12 col-md-auto w-md-80px order-2 order-md-1 mt-3 mt-md-0">
                            <div class="aiz-carousel product-gallery-thumb " data-items="7" data-nav-for=".product-gallery" data-vertical="true" data-vertical-sm="false" data-focus-select="true" data-arrows="true">
                                @foreach (var item in Model.Product.Image.Split('|'))
                                {
                                    @if (!String.IsNullOrEmpty(item))
                                    {
                                        <div>
                                            <div class="carousel-box c-pointer border p-1 rounded" style="width: 100%; display: inline-block;">
                                                <img class="mw-100 size-50px mx-auto ls-is-cached lazyloaded" src="@item" data-src="@item" onerror="this.onerror=null;this.src='/img/placeholder.jpg';">
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-xl-7 col-lg-6">
                    <div class="text-left">
                        <h1 class="mb-2 fs-20 fw-600">
                            @Model.Product.Name
                        </h1>

                        <div class="row align-items-center" style="margin-top:14px;">
                            <div class="col-12">
                                <span class="rating">
                                    <i class="las la-star"></i><i class="las la-star"></i><i class="las la-star"></i><i class="las la-star"></i><i class="las la-star"></i>
                                </span>
                                <span class="ml-1 opacity-50">
                                    (@Model.Product.Feedback
                                    Đánh giá)
                                </span>
                            </div>
                        </div>

                        <hr style="margin-top:18px;">

                        <div class="row align-items-center">
                            <div class="col-auto">
                                <small class="mr-2 opacity-50">Được bán bởi: </small><br>
                                <a href="/detailproduct" class="text-reset">@Model.Product.Company</a>
                            </div>
                            <div class="col-auto">
                                <button class="btn btn-sm btn-soft-primary" onclick="show_chat_modal()">Chat với Người bán</button>
                            </div>

                        </div>

                        <hr>

                        <div class="row no-gutters mt-3">
                            <div class="col-sm-2">
                                <div class="opacity-50 my-2">Giá bán:</div>
                            </div>
                            <div class="col-sm-10">
                                <div class="">
                                    <strong class="h2 fw-600 text-primary">
                                        @Model.Product.Price.ToString("N0") @Model.Product.UnitPrice
                                    </strong>
                                    <span class="opacity-70">/@Model.Product.Unit</span>
                                </div>
                            </div>
                        </div>


                        <hr>

                        <form id="option-choice-form">
                            <input type="hidden" name="_token" value="TbTOAsxlbGF76jRH4aksgWpsuHDxEBznz2hNl3NN">
                            <input type="hidden" name="id" value="@Model.Product.Id">



                            <!-- Quantity + Add to cart -->
                            <div class="row no-gutters">
                                <div class="col-sm-2">
                                    <div class="opacity-50 my-2">Số lượng:</div>
                                </div>
                                <div class="col-sm-10">
                                    <div class="product-quantity d-flex align-items-center">
                                        <div class="row no-gutters align-items-center aiz-plus-minus mr-3" style="width: 130px;">
                                            <button class="btn col-auto btn-icon btn-sm btn-circle btn-light" type="button" data-type="minus" data-field="quantity" disabled="disabled">
                                                <i class="las la-minus"></i>
                                            </button>
                                            <input type="number" name="quantity" class="col border-0 text-center flex-grow-1 fs-16 input-number" placeholder="1" value="1" min="1" max="@Model.Product.Quantity" lang="en">
                                            <button class="btn  col-auto btn-icon btn-sm btn-circle btn-light" type="button" data-type="plus" data-field="quantity">
                                                <i class="las la-plus"></i>
                                            </button>
                                        </div>
                                        <div class="avialable-amount opacity-60">
                                            (<span id="available-quantity">@Model.Product.Quantity</span>
                                            Còn hàng)
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <hr>

                            <div class="row no-gutters pb-3" id="chosen_price_div">
                                <div class="col-sm-2">
                                    <div class="opacity-50 my-2">Tổng giá:</div>
                                </div>
                                <div class="col-sm-10">
                                    <div class="product-price">
                                        <strong id="chosen_price" class="h4 fw-600 text-primary">@Model.Product.Price.ToString("N0") @Model.Product.UnitPrice</strong>
                                    </div>
                                </div>
                            </div>

                        </form>
                        <div class="mt-3">
                            <button type="button" class="btn btn-soft-primary mr-2 add-to-cart fw-600" onclick="addToCart()">
                                <i class="las la-shopping-bag"></i>
                                <span class="d-none d-md-inline-block">
                                    Thêm vào giỏ hàng
                                </span>
                            </button>
                            <button type="button" class="btn btn-primary buy-now fw-600" onclick="buyNow()">
                                <i class="la la-shopping-cart"></i> Mua ngay
                            </button>
                            <button type="button" class="btn btn-secondary out-of-stock fw-600 d-none" disabled="">
                                <i class="la la-cart-arrow-down"></i> Hết hàng
                            </button>
                        </div>



                        <div class="d-table width-100 mt-3">
                            <div class="d-table-cell">
                                <!-- Add to wishlist button -->
                                <button type="button" class="btn pl-0 btn-link fw-600" onclick="addToWishList(@Model.Product.Id)">
                                    Thêm vào danh sách yêu thích
                                </button>
                                <!-- Add to compare button -->

                            </div>
                        </div>


                        <div class="row no-gutters mt-4 justify-content-center align-items-center">
                            <div class="col-sm-2">
                                <div class="opacity-50 my-2">Chia sẻ:</div>
                            </div>
                            <div class="col-sm-10">
                                <div class="aiz-share jssocials"><div class="jssocials-shares"><div class="jssocials-share jssocials-share-email"><a target="_self" href="" class="jssocials-share-link"><i class="lab la-whatsapp jssocials-share-logo"></i></a></div></div></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<section class="mb-4">
    <div class="container">
        <div class="row gutters-10">
            <div class="col-xl-12 order-0 order-xl-0 block">
                <div class="bg-white shadow-sm mb-4">
                    <div class="product-well p-3 pb-5">
                        <div class="row">
                            <div class="col-md-6 col-sm-12 col-12">
                                <h3 class="fs-16 fw-600 border-bottom pb-3 mb-3">
                                    <span>Đặc điểm nổi bật</span>
                                </h3>
                                <div class="wysiwyg">
                                </div>
                            </div>
                            <div class="col-md-6 col-sm-12 col-12">
                                <h3 class="fs-16 fw-600 border-bottom pb-3 mb-3">
                                    <span>Điều kiện sử sụng</span>
                                </h3>
                                <div class="wysiwyg">
                                </div>
                            </div>
                        </div>
                        <a class="btn btn-default btn-view-more">
                            <span class="more-text">Xem thêm <i class="la la-chevron-down"></i></span>
                            <span class="less-text">Thu gọn <i class="la la-chevron-up"></i></span>
                        </a>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 order-1 order-xl-0">
                <div class="bg-white shadow-sm mb-3">
                    <div class="position-relative p-3 text-left">
                        <div class="absolute-top-right p-2 bg-white z-1">
                            <svg version="1.1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" xml:space="preserve" viewBox="0 0 287.5 442.2" width="22" height="34">
                            <polygon style="fill:#F8B517;" points="223.4,442.2 143.8,376.7 64.1,442.2 64.1,215.3 223.4,215.3 "></polygon>
                            <circle style="fill:#FBD303;" cx="143.8" cy="143.8" r="143.8"></circle>
                            <circle style="fill:#F8B517;" cx="143.8" cy="143.8" r="93.6"></circle>
                            <polygon style="fill:#FCFCFD;" points="143.8,55.9 163.4,116.6 227.5,116.6 175.6,154.3 195.6,215.3 143.8,177.7 91.9,215.3 111.9,154.3
                                            60,116.6 124.1,116.6 "></polygon>
                                        </svg>
                        </div>
                        <div class="opacity-50 fs-12 border-bottom">Được bán bởi</div>
                        <a href="/detailproduct" class="text-reset d-block fw-600">
                            @Model.Product.Company
                            <span class="ml-2"><i class="fa fa-check-circle" style="color:green"></i></span>
                        </a>
                        <div class="location opacity-70">
                            @Model.Product.CompanyAddress
                        </div>
                        <div class="text-center border rounded p-2 mt-3">
                            <div class="rating">
                                <i class="las la-star"></i><i class="las la-star"></i><i class="las la-star"></i><i class="las la-star"></i><i class="las la-star"></i>
                            </div>
                            <div class="opacity-60 fs-12">
                                (@Model.Product.Feedback
                                Phản hồi khách hàng)
                            </div>
                        </div>
                    </div>
                    <div class="row no-gutters align-items-center border-top left-social">
                        <div class="col">
                            <a href="/detailproduct" class="d-block btn btn-soft-primary rounded-0">Xem gian hàng</a>
                        </div>
                        <div class="col">
                            <ul class="social list-inline mb-0">
                                <li class="list-inline-item">
                                    <a href="/detailproduct" class="facebook" target="_blank">
                                        <i class="lab la-facebook-f opacity-60"></i>
                                    </a>
                                </li>
                                <li class="list-inline-item">
                                    <a href="/detailproduct" class="instagram" target="_blank">
                                        <i class="lab la-instagram opacity-60"></i>
                                    </a>
                                </li>
                                <li class="list-inline-item">
                                    <a href="/detailproduct" class="website" target="_blank">
                                        <i class="las la-globe opacity-60"></i>
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
                <div class="bg-white rounded shadow-sm mb-3">
                    <div class="p-3 border-bottom fs-16 fw-600">
                        Sản phẩm bán chạy nhất
                    </div>
                    <div class="p-3">
                        <ul class="list-group list-group-flush">
                            @foreach (var product in Model.ProductByCatgory)
                            {
                                <li class="py-3 px-0 list-group-item border-light">
                                    <div class="row gutters-10 align-items-center">
                                        <div class="col-5">
                                            <a href="/product/@product.Slug-@product.Id" class="d-block text-reset">
                                                <img class="img-fit h-xxl-110px h-xl-80px h-120px ls-is-cached lazyloaded" src="@product.Image.Split('|')[0]" data-src="@product.Image.Split('|')[0]" alt="@product.Name" onerror="this.onerror=null;this.src='/img/placeholder.jpg';">
                                            </a>
                                        </div>
                                        <div class="col-7 text-left">
                                            <h4 class="fs-14">
                                                <a href="/detailproduct" class="d-block text-reset">@product.Name</a>
                                            </h4>
                                            <div class="rating rating-sm mt-1">
                                                <i class="las la-star"></i><i class="las la-star"></i><i class="las la-star"></i><i class="las la-star"></i><i class="las la-star"></i>
                                            </div>
                                            <div class="mt-2">
                                                <span class="fs-17 fw-600 text-primary">@product.Price.ToString("N0") @product.UnitPrice</span>
                                            </div>
                                        </div>
                                    </div>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
            <div class="col-xl-9 order-0 order-xl-1">
                <div class="bg-white mb-3 shadow-sm rounded">
                    <div class="nav border-bottom aiz-nav-tabs">
                        <a href="#tab_default_1" data-toggle="tab" class="p-3 fs-16 fw-600 text-reset active show">Mô tả</a>

                        <a href="#tab_default_4" data-toggle="tab" class="p-3 fs-16 fw-600 text-reset">Đánh giá</a>
                    </div>

                    <div class="tab-content pt-0">
                        <div class="tab-pane fade active show" id="tab_default_1">
                            <div class="p-4">
                                <div class="mw-100 overflow-hidden text-left aiz-editor-data">
                                    <p style="margin-bottom: 1.3em; color: rgb(10, 10, 10); font-family: Asap, sans-serif; font-size: 16px;">
                                        <span style="font-weight: bolder;">@Model.Product.Name</span>
                                        </p>
                                    <p style="margin-bottom: 1.3em; color: rgb(10, 10, 10); font-family: Asap, sans-serif; font-size: 16px;">Được sơ chế từ những hạt bắp tươi ngon, ngọt, mát, bùi mang lại cảm giác thú vị cho người thưởng thức, sản phẩm an toàn cho sức khỏe người sử dụng.</p>
                                    <h2 style="text-rendering: optimizespeed; color: rgb(209, 92, 17); margin-bottom: 0.5em; width: 854.2px; line-height: 1.3; font-size: 1.6em; font-family: Asap, sans-serif; font-weight: 700;">
                                        <span style="font-weight: bolder;">Thông Tin Sản Phẩm:</span></h2><ul style="list-style-position: initial; list-style-image: initial; padding: 0px; margin-bottom: 1.3em; color: rgb(10, 10, 10); font-family: Asap, sans-serif; font-size: 16px;">
                                        <li aria-level="1" style="margin-bottom: 0.6em; margin-left: 1.3em;"><span style="font-weight: bolder;">Tên sản phẩm</span>: Ngô ngọt nguyên hạt - Ngô Ngọt nguyên hạt AS</li>
                                        <li aria-level="1" style="margin-bottom: 0.6em; margin-left: 1.3em;"><span style="font-weight: bolder;">Xuất xứ</span>: Công ty thực phẩm Dũng Hà</li>
                                        <li aria-level="1" style="margin-bottom: 0.6em; margin-left: 1.3em;"><span style="font-weight: bolder;">Đóng gói</span>: Hộp</li>
                                    </ul><h2 style="text-rendering: optimizespeed; color: rgb(209, 92, 17); margin-bottom: 0.5em; width: 854.2px; line-height: 1.3; font-size: 1.6em; font-family: Asap, sans-serif; font-weight: 700;">
                                        <span style="font-weight: bolder;">Mô Tả Sản Phẩm:</span>
                                    </h2><p style="margin-bottom: 1.3em; color: rgb(10, 10, 10); font-family: Asap, sans-serif; font-size: 16px;">
                                        Ngô ngọt đóng hộp đảm bảo an toàn vệ sinh thực phẩm được chế biến theo quy trình tiêu chuẩn.<br/>
                                        + Thành phần : Ngô ngọt, Nước, Đường mía, Muối ăn.<br />
                                        + Trọng lượng tĩnh : 450gr. Trọng lượng cái : 230gr.<br />
                                        + Sử dụng : Ăn liền, chiên bơ, đồ xôi, rang cơm, nấu canh, nấu chè và các món ăn khác.<br />
                                        + Hạn sử dụng : 2 năm kể từ ngày SX .Ngày sản xuất và hạn sử dụng ghi trên bao bì.<br />
                                        + Bảo quản : Bảo quản nơi khô ráo thoáng mát, tránh ánh nắng. Bảo quản lạnh sau khi mở và sử dụng .<br />
                                    </p><p style="margin-bottom: 1.3em; color: rgb(10, 10, 10); font-family: Asap, sans-serif; font-size: 16px;">
                                        <span style="font-weight: bolder;">Ưu Điểm Nổi Bật</span>:</p>
                                        <ul style="list-style-position: initial; list-style-image: initial; padding: 0px; margin-bottom: 1.3em; color: rgb(10, 10, 10); font-family: Asap, sans-serif; font-size: 16px;"><li aria-level="1" style="margin-bottom: 0.6em; margin-left: 1.3em;">
                                            <span style="font-weight: bolder;">Hương vị đặc trưng</span>: Ngô ngọt có hương vị thơm ngon, đậm đà.</li><li aria-level="1" style="margin-bottom: 0.6em; margin-left: 1.3em;">
                                                <span style="font-weight: bolder;">Chất lượng cao</span>: Sản phẩm được làm từ ngô không biến đổi gen, không chứa chất bảo quản hay phụ gia.</li>
                                                <li aria-level="1" style="margin-bottom: 0.6em; margin-left: 1.3em;"><span style="font-weight: bolder;">Dinh dưỡng</span>: Ngô ngọt giàu protein và các khoáng chất cần thiết, tốt cho sức khỏe.</li></ul><h2 style="text-rendering: optimizespeed; color: rgb(209, 92, 17); margin-bottom: 0.5em; width: 854.2px; line-height: 1.3; font-size: 1.6em; font-family: Asap, sans-serif; font-weight: 700;"><span style="font-weight: bolder;">Cách Sử Dụng:</span></h2><ul style="list-style-position: initial; list-style-image: initial; padding: 0px; margin-bottom: 1.3em; color: rgb(10, 10, 10); font-family: Asap, sans-serif; font-size: 16px;"><li aria-level="1" style="margin-bottom: 0.6em; margin-left: 1.3em;"><span style="font-weight: bolder;">Ăn trực tiếp</span>: Là món ăn vặt giàu dinh dưỡng, phù hợp cho mọi lứa tuổi.</li><li aria-level="1" style="margin-bottom: 0.6em; margin-left: 1.3em;"><span style="font-weight: bolder;">Chế biến món ăn</span>: Có thể kết hợp với các loại rau củ và gia vị để tạo nên các món ăn ngon miệng và bổ dưỡng.</li></ul><h2 style="text-rendering: optimizespeed; color: rgb(209, 92, 17); margin-bottom: 0.5em; width: 854.2px; line-height: 1.3; font-size: 1.6em; font-family: Asap, sans-serif; font-weight: 700;"><span style="font-weight: bolder;">Cách Bảo Quản:</span></h2><ul style="list-style-position: initial; list-style-image: initial; padding: 0px; margin-bottom: 1.3em; color: rgb(10, 10, 10); font-family: Asap, sans-serif; font-size: 16px;"><li aria-level="1" style="margin-bottom: 0.6em; margin-left: 1.3em;"><span style="font-weight: bolder;">Bảo quản nơi khô ráo, thoáng mát</span>: Để thịt trâu gác bếp ở nơi khô ráo và thoáng mát để giữ được độ giòn và hương vị lâu dài.</li><li aria-level="1" style="margin-bottom: 0.6em; margin-left: 1.3em;"><span style="font-weight: bolder;">Sử dụng trong thời gian ngắn sau khi mở bao bì</span>: Để đảm bảo chất lượng, nên sử dụng sản phẩm trong vòng một tuần sau khi mở bao bì.</li></ul><p style="margin-bottom: 1.3em; color: rgb(10, 10, 10); font-family: Asap, sans-serif; font-size: 16px;">Thời gian vận chuyển cho đơn Thịt trâu gác bếp:</p><p style="margin-bottom: 1.3em; color: rgb(10, 10, 10); font-family: Asap, sans-serif; font-size: 16px;">+ Nội thành TP.HCM: 1 đến 2 hôm</p><p style="margin-bottom: 1.3em; color: rgb(10, 10, 10); font-family: Asap, sans-serif; font-size: 16px;">+ Các tỉnh ngoại thành : 3 đến 5 hôm</p><p style="margin-bottom: 1.3em; color: rgb(10, 10, 10); font-family: Asap, sans-serif; font-size: 16px;">+ Hỗ trợ hỏa tốc: 1 giờ đến 3 giờ</p><p style="margin-bottom: 1.3em; color: rgb(10, 10, 10); font-family: Asap, sans-serif; font-size: 16px;">**VÀI LY ĐÊ CAM KẾT VỚI KHÁCH HÀNG:</p><p style="margin-bottom: 1.3em; color: rgb(10, 10, 10); font-family: Asap, sans-serif; font-size: 16px;">– Sản phẩm giống mô tả.</p><p style="margin-bottom: 1.3em; color: rgb(10, 10, 10); font-family: Asap, sans-serif; font-size: 16px;">– Nguyên liệu thực phẩm tươi sạch, không chất bảo quản.</p><p style="margin-bottom: 1.3em; color: rgb(10, 10, 10); font-family: Asap, sans-serif; font-size: 16px;">– Đơn hàng được giao từ 1-5 ngày kể từ ngày đặt hàng.</p><p style="margin-bottom: 1.3em; color: rgb(10, 10, 10); font-family: Asap, sans-serif; font-size: 16px;">– Trả hàng nếu sản phẩm bị lỗi, hỏng, cam kết giải quyết 100% không để khách thiệt.</p><p style="margin-bottom: 1.3em; color: rgb(10, 10, 10); font-family: Asap, sans-serif; font-size: 16px;">*QUY ĐỊNH BẢO HÀNH, ĐỔI TRẢ *(QUAY VIDEO KHI MỞ HÀNG)</p><p style="margin-bottom: 1.3em; color: rgb(10, 10, 10); font-family: Asap, sans-serif; font-size: 16px;">1.Điều kiện áp dụng (trong vòng 3 ngày kể khi nhận được sản phẩm)</p><p style="margin-bottom: 1.3em; color: rgb(10, 10, 10); font-family: Asap, sans-serif; font-size: 16px;">– Hàng hóa vẫn còn nguyên seal chưa tháo bịch , nguyên vẹn chưa qua sử dụng.</p><p style="margin-bottom: 1.3em; color: rgb(10, 10, 10); font-family: Asap, sans-serif; font-size: 16px;">– Sản phẩm bị lỗi do vận chuyển hoặc lỗi do nhà sản xuất. Sản phẩm có dấu hiệu hư hỏng do ảnh hưởng không mong muốn ( do hàng không chất bảo quản, nên đôi lúc sẽ có sản phẩm bị hỏng trước hạn sử dụng, đây là điều bên Vài Ly Đê không mong muốn và cam kết bù-đổi cho khách ).</p><p style="margin-bottom: 1.3em; color: rgb(10, 10, 10); font-family: Asap, sans-serif; font-size: 16px;">2.Trường hợp được chấp nhận</p><p style="margin-bottom: 1.3em; color: rgb(10, 10, 10); font-family: Asap, sans-serif; font-size: 16px;">– Hàng không đúng trọng lượng, mẫu mã như quý khách đặt hàng.</p><p style="margin-bottom: 1.3em; color: rgb(10, 10, 10); font-family: Asap, sans-serif; font-size: 16px;">– Không đủ số lượng như trong đơn hàng.</p><p style="margin-bottom: 1.3em; color: rgb(10, 10, 10); font-family: Asap, sans-serif; font-size: 16px;">3.Trường hợp không đủ điều kiện áp dụng chính sách:</p><p style="margin-bottom: 1.3em; color: rgb(10, 10, 10); font-family: Asap, sans-serif; font-size: 16px;">– Quá 3 ngày sau khi nhận hàng.</p><p style="margin-bottom: 1.3em; color: rgb(10, 10, 10); font-family: Asap, sans-serif; font-size: 16px;">– Gửi lại hàng không đúng sản phẩm.</p><p style="margin-bottom: 1.3em; color: rgb(10, 10, 10); font-family: Asap, sans-serif; font-size: 16px;">– Đặt nhầm sản phẩm, chủng loại, không thích</p>
                                </div>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="tab_default_2">
                            <div class="p-4">
                                <div class="embed-responsive embed-responsive-16by9">
                                </div>
                            </div>
                        </div>
                        <div class="tab-pane fade" id="tab_default_3">
                            <div class="p-4 text-center ">
                                <a href="" class="btn btn-primary">Tải xuống</a>
                            </div>
                        </div>
                        <div class="tab-pane fade" id="tab_default_4">
                            <div class="p-4">
                                <ul class="list-group list-group-flush">
                                </ul>

                                <div class="text-center fs-18 opacity-70">
                                    Chưa có nhận xét nào cho sản phẩm này.
                                </div>

                            </div>
                        </div>

                    </div>
                </div>
                <div class="bg-white rounded shadow-sm">
                    <div class="border-bottom p-3">
                        <h3 class="fs-16 fw-600 mb-0">
                            <span class="mr-4">Sản phẩm tương ứng</span>
                        </h3>
                    </div>
                    <div class="p-3">
                        <div class="aiz-carousel gutters-5 half-outside-arrow " data-items="5" data-xl-items="3" data-lg-items="4" data-md-items="3" data-sm-items="2" data-xs-items="2" data-arrows="true" data-infinite="true">
                            @foreach (var product in Model.Products)
                            {
                                <div>
                                    <div class="carousel-box" style="width: 100%; display: inline-block;">
                                        <div class="aiz-card-box border border-light rounded hov-shadow-md my-2 has-transition">
                                            <div class="">
                                                <a href="/product/@product.Slug-@product.Id" class="d-block" tabindex="-1">
                                                    <img class="img-fit mx-auto ls-is-cached lazyloaded" src="@product.Image.Split('|')[0]" data-src="@product.Image.Split('|')[0]" alt="@product.Name" onerror="this.onerror=null;this.src='/img/placeholder.jpg';">
                                                </a>
                                            </div>
                                            <div class="p-md-3 p-2 text-left">
                                                <div class="fs-15">
                                                    <span class="fw-700 text-primary">@product.Price.ToString("N0") @product.UnitPrice</span>
                                                </div>
                                                <div class="rating rating-sm mt-1">
                                                    <i class="las la-star"></i><i class="las la-star"></i><i class="las la-star"></i><i class="las la-star"></i><i class="las la-star"></i>
                                                </div>
                                                <h3 class="fw-600 fs-16 text-truncate-2 lh-1-4 mb-0 h-37px">
                                                    <a href="/product/@product.Slug-@product.Id" class="d-block text-reset" tabindex="-1">@product.Name</a>
                                                </h3>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>